# Server
SERVER_PORT=8080
CLIENT_URL=http://localhost:3000

# Application Init
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PHONE=0354802825

# Database
DB_URL=jdbc:postgresql://localhost:5432/Zola
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Email (Brevo - https://app.brevo.com)
EMAIL_HOST=https://api.brevo.com
EMAIL_API_KEY=your_brevo_api_key
EMAIL_SENDER_EMAIL=your_sender_email@example.com
EMAIL_SENDER_NAME=Your Name

# JWT (use a strong random hex string, min 64 chars)
JWT_ACCESS_SIGNER_KEY=your_access_signer_key
JWT_REFRESH_SIGNER_KEY=your_refresh_signer_key
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=604800

# OTP
OTP_EXPIRATION=5

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
