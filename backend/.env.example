# Server
SERVER_PORT=8080
CLIENT_URL=http://localhost:3000

# Socket Server
SOCKET_SERVER_HOST=0.0.0.0
SOCKET_SERVER_PORT=9999

# Application Init
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PHONE=0354802825

# Default Avatar
DEFAULT_AVATAR_URL=https://static.vecteezy.com/system/resources/thumbnails/001/840/618/small/picture-profile-icon-male-icon-human-or-people-sign-and-symbol-free-vector.jpg

# Database
DB_URL=jdbc:postgresql://localhost:5432/Zola
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Redis config: Run: docker run --name redis-zola -p 6379:6379 -d redis
# Exec: docker exec -it redis-zola redis-cli => Test connection: PING => Should return PONG. Set password: CONFIG SET requirepass 123456
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456

# Email (Brevo - https://app.brevo.com)
EMAIL_HOST=https://api.brevo.com
EMAIL_API_KEY=your_brevo_api_key
EMAIL_SENDER_EMAIL=your_sender_email@example.com
EMAIL_SENDER_NAME=Zola

# JWT (use a strong random hex string, min 64 chars)
JWT_ACCESS_SIGNER_KEY=your_access_signer_key
JWT_REFRESH_SIGNER_KEY=your_refresh_signer_key
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=604800

# OTP
OTP_EXPIRATION=5

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI
SPRING_AI_MODEL_CHAT=google-genai
GOOGLE_GENAI_API_KEY=your-key
GOOGLE_GENAI_MODEL=gemini-3-flash-preview
GOOGLE_GENAI_EMBEDDING_MODEL=gemini-embedding-001