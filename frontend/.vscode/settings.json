{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "[typescript]": {
    "editor.tabSize": 4
  },
  "[typescriptreact]": {
    "editor.tabSize": 4
  },
  "[javascript]": {
    "editor.tabSize": 4
  },
  "[json]": {
    "editor.tabSize": 2
  }
}
